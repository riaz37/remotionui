{
  "name": "remotion-ui",
  "version": "0.4.1",
  "description": "Copy-paste Remotion video components you own. Registry-first CLI — install source into your repo.",
  "homepage": "https://remotionui.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/riaz37/remotionui.git",
    "directory": "packages/remotion-ui"
  },
  "bugs": {
    "url": "https://github.com/riaz37/remotionui/issues"
  },
  "keywords": [
    "remotion",
    "video",
    "react",
    "cli",
    "components",
    "registry"
  ],
  "license": "MIT",
  "type": "module",
  "bin": {
    "remotion-ui": "./dist/index.js"
  },
  "files": ["dist", "templates"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./schema": {
      "types": "./dist/schema/index.d.ts",
      "default": "./dist/schema/index.js"
    },
    "./registry": {
      "types": "./dist/registry/index.d.ts",
      "default": "./dist/registry/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "pnpm build",
    "dev": "tsup --watch",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "publish:npm": "npm publish --access public"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "cosmiconfig": "^9.0.0",
    "fs-extra": "^11.3.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@remotionui/typescript-config": "workspace:*",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.13.4",
    "tsup": "^8.3.6",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  },
  "publishConfig": {
    "access": "public"
  }
}
